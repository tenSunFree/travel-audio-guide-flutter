#!/bin/sh
# .git/hooks/pre-push
#
# Runs local CI checks before every push.
# Install: cp scripts/pre-push .git/hooks/pre-push && chmod +x .git/hooks/pre-push

cd "$(git rev-parse --show-toplevel)"

echo ""
echo "pre-push: running local checks..."

bash scripts/check.sh

if [ $? -ne 0 ]; then
  echo ""
  echo "pre-push: checks failed. Fix errors before pushing."
  exit 1
fi

echo ""
echo "pre-push: all checks passed."
exit 0
