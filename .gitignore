# Miscellaneous
*.class
*.log
*.pyc
*.swp
.DS_Store
.atom/
.build/
.buildlog/
.history
.svn/
.swiftpm/
migrate_working_dir/

# IntelliJ related
*.iml
*.ipr
*.iws
.idea/

# The .vscode folder contains launch configuration and tasks you configure in
# VS Code which you may wish to be included in version control, so this line
# is commented out by default.
#.vscode/

# Flutter/Dart/Pub related
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins-dependencies
.pub-cache/
.pub/
/build/
/coverage/

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release

# Android build outputs
android/build/
android/.gradle/
android/**/build/

# Environment config (real environment values not included in Git)
# example.json is a template and is included in Git
# dev.json release.json contains the real key and is not included in Git
env/dev.json
env/release.json

# Firebase config - public repo, Submitting is not recommended
android/app/google-services.json
ios/Runner/GoogleService-Info.plist
lib/config/firebase/firebase_options.dart

# google-services.json split according to flavor
android/app/src/staging/google-services.json
android/app/src/production/google-services.json

# Firebase options split according to environment
lib/config/firebase/firebase_options_staging.dart
lib/config/firebase/firebase_options_production.dart

# Release signature settings (absolutely do not commit)
android/key.properties
android/app/*.keystore
android/app/*.jks

# Never commit Firebase / Google Cloud service account keys
secrets/
*.json.key
*service-account*.json
*-firebase-adminsdk-*.json
travel-audio-guide-flutter-*.json
*.jks
*.keystore
key.properties